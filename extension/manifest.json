{
  "manifest_version": 3,
  "name": "VeriXa — Fact Verification",
  "version": "1.0.0",
  "description": "Right-click any text on any webpage and verify it instantly with VeriXa AI fact-checking engine.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": [
    "https://verixa-gamma.vercel.app/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
