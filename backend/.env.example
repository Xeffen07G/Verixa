# VeriXa Backend Configuration
# Copy this file to .env and fill in your actual values

# AI Services
GEMINI_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Database (MongoDB Atlas recommended)
MONGO_URI=

# Async Jobs & Caching (Redis)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=

# Server Settings
PORT=5000
NODE_ENV=production

# Frontend
FRONTEND_URL=https://verixa.io